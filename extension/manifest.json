{
  "manifest_version": 3,
  "name": "KesKonMange",
  "version": "1.0",
  "description": "Ajouter une recette à KesKonMange",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}